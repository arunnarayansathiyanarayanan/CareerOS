{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.aihired.in" }],
      "destination": "https://aihired.in/:path*",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/roadmap-regen",
      "schedule": "30 20 * * 0"
    },
    {
      "path": "/api/cron/streak-reset",
      "schedule": "35 18 * * *"
    },
    {
      "path": "/api/cron/leaderboard-refresh",
      "schedule": "30 20 * * *"
    },
    {
      "path": "/api/cron/challenge-lifecycle",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/peer-review-reminder",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/skill-intelligence?job=scrape",
      "schedule": "30 17 * * 6"
    },
    {
      "path": "/api/cron/skill-intelligence?job=aggregate",
      "schedule": "30 20 * * 0"
    },
    {
      "path": "/api/cron/skill-intelligence?job=email",
      "schedule": "30 2 1 * *"
    }
  ]
}
